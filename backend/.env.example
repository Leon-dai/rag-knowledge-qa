# 阿里云百炼 DashScope API Key（必填）
# 获取地址: https://help.aliyun.com/zh/model-studio/get-api-key
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# JWT 密钥（必填，使用 python -c "import secrets; print(secrets.token_urlsafe(32))" 生成）
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# 管理员初始密码（可选，不设置则首次启动时随机生成并打印到日志）
# ADMIN_PASSWORD=

# 数据库（SQLite 文件路径，相对于 backend/ 目录）
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# ChromaDB 持久化路径
CHROMA_PERSIST_DIR=./data/chroma_db

# 文件上传路径
UPLOAD_DIR=./data/uploads

# 缓存路径
CACHE_DIR=./data/cache

# 服务配置
HOST=127.0.0.1
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
